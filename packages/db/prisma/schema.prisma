// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
// Enums
enum Role {
  USER
  ADMIN
}

enum Department {
  IT
  HR
  FINANCE
  SALES
  MARKETING
  OPERATIONS
  MANAGEMENT
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Models
model User {
  id         String     @id @default(uuid())
  externalId String     @unique // Mapped from external auth server
  email      String     @unique
  password   String?    @db.VarChar(255) // For NextAuth Credentials Provider
  name       String
  role       Role       @default(USER)
  department Department @default(GENERAL)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  // Relations
  submittedTickets  Ticket[]        @relation("SubmittedTickets")
  assignedTickets   Ticket[]        @relation("AssignedTickets")
  comments          Comment[]
  attachments       Attachment[]
  notifications     Notification[]
  ticketHistoryLogs TicketHistory[]
  adminSkills       AdminSkill[]

  @@map("users")
}

model Location {
  id           String   @id @default(uuid())
  buildingName String
  floor        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tickets Ticket[]

  @@map("locations")
}

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  // Auditing
  // Auditing & SLA
  firstRespondedAt DateTime? // Time when the first admin reply was added
  resolvedAt       DateTime? // Time when the ticket status was changed to RESOLVED
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Foreign Keys
  submitterId String
  assigneeId  String?
  locationId  String?
  categoryId  String

  // Relations
  // Relations
  submitter     User            @relation("SubmittedTickets", fields: [submitterId], references: [id])
  assignee      User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  location      Location?       @relation(fields: [locationId], references: [id])
  category      Category        @relation(fields: [categoryId], references: [id])
  historyLogs   TicketHistory[]
  comments      Comment[]
  attachments   Attachment[]
  notifications Notification[]

  // Indexes for faster filtering in the admin dashboard (Agent Feedback)
  @@index([status])
  @@index([priority])
  @@index([submitterId])
  @@index([assigneeId])
  @@map("tickets")
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign Keys
  ticketId String
  authorId String

  // Relations
  // Relations
  ticket      Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade) // Cascade delete (Agent Feedback)
  author      User         @relation(fields: [authorId], references: [id])
  attachments Attachment[]

  @@index([ticketId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String   @db.VarChar(255)
  fileUrl   String   @db.Text
  fileSize  Int
  mimeType  String   @db.VarChar(100)
  createdAt DateTime @default(now())

  // Foreign Keys
  ticketId     String?
  commentId    String?
  uploadedById String

  // Relations
  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@index([commentId])
  @@map("attachments")
}

enum NotificationType {
  TICKET_CREATED
  TICKET_ASSIGNED
  TICKET_STATUS_CHANGED
  NEW_COMMENT
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String?          @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Foreign Keys
  userId   String
  ticketId String?

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Category?        @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[]       @relation("SubCategories")
  tickets     Ticket[]
  accessRules CategoryAccess[]
  adminSkills AdminSkill[]

  @@map("categories")
}

model CategoryAccess {
  id         String      @id @default(uuid())
  categoryId String
  department Department? // null means applies to all departments
  role       Role? // null means applies to all roles

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("category_access")
}

enum HistoryAction {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNEE_CHANGED
  CATEGORY_CHANGED
  TRANSFERRED
}

model TicketHistory {
  id          String        @id @default(uuid())
  ticketId    String
  changedById String
  action      HistoryAction
  oldValue    String?
  newValue    String?
  note        String?       @db.Text
  createdAt   DateTime      @default(now())

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy User   @relation(fields: [changedById], references: [id])

  @@index([ticketId])
  @@index([changedById])
  @@map("ticket_history")
}

model AdminSkill {
  userId     String
  categoryId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
  @@index([userId])
  @@map("admin_skills")
}
